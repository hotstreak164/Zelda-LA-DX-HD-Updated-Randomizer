[Game: Advanced Settings]
// Various options to modify the base game in some way.

//: Game1
// Forces "Editor Mode" giving access to the map editor and developer/debugging option. Usually accessed via command line option "editor" but can be enabled here too.
// Default: false
editor_mode = false

//: Game1
// Modifies the maximum scaling value available in-game. Game automatically adds +1 for the "Auto-Detect" option (so value of 50 is actually 51).
// Default: 20
