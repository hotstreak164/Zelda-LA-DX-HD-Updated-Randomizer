//------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

[Game: Textbox Overlay]
// Modifies the scaling size of texboxes.

//: TextboxOverlay
// The scaling value used for textboxes. Use a value of "0" to use game default. This value should probably not exceed 6-10 on screens even up to 3840x2160 resolution.
// Default: 0
textbox_scale = 0

//------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

[Game: HUD Overlay]
