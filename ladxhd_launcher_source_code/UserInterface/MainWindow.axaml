<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="550" d:DesignHeight="768"
        x:Class="LADXHD_Launcher.MainWindow"
        Title="The Legend of Zelda: Link's Awakening DX HD"
        Width="550"
        Height="768"
        MinWidth="550"
        MaxWidth="550"
        MinHeight="400"
        MaxHeight="768"
		CanMaximize="False"
        WindowStartupLocation="CenterScreen"
        Icon="avares://Launcher/Resources/icon.ico">

    <Panel>
        <Image Source="avares://Launcher/Resources/background.png"
               Stretch="Fill" />
        <ContentControl x:Name="PageContent" />
        <Image x:Name="LoadingNotification"
               Source="avares://Launcher/Resources/load_message.png"
               Stretch="None"
               Opacity="0"
               IsHitTestVisible="False"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
        <Image x:Name="SavedNotification"
               Source="avares://Launcher/Resources/saved_message.png"
               Stretch="None"
               Opacity="0"
               IsHitTestVisible="False"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
		<Image x:Name="ResetNotification"
			   Source="avares://Launcher/Resources/reset_message.png"
			   Stretch="None"
			   Opacity="0"
			   IsHitTestVisible="False"
			   HorizontalAlignment="Center"
			   VerticalAlignment="Center" />

    </Panel>
    <Window.Styles>
        <!-- Button Style -->
        <Style Selector="Button">
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <!-- CheckBox Style -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style Selector="CheckBox /template/ Border#NormalRectangle">
            <Setter Property="BorderBrush" Value="White" />
        </Style>
    </Window.Styles>
</Window>