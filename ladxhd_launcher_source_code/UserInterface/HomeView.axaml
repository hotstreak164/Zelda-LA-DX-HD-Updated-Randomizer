<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="550" d:DesignHeight="768"
             x:Class="LADXHD_Launcher.HomeView">

    <Canvas>
		<!-- Sound Toggle Button -->
		<Button Canvas.Left="500" Canvas.Top="10" Width="40" Height="30"
				Click="SoundToggle_Click"
				Background="Transparent" BorderThickness="0" Padding="0">
			<Image x:Name="SoundButtonImage"
				   Source="avares://Launcher/Resources/sound_on.png"
				   Stretch="Fill" />
		</Button>

        <!-- Play Button -->
        <Button Canvas.Left="30" Canvas.Top="710" Width="80" Height="34"
                Click="PlayButton_Click">
            <Image Source="avares://Launcher/Resources/button_play.png"
                   Stretch="None" />
        </Button>
        <!-- Settings Button -->
        <Button Canvas.Left="144" Canvas.Top="710" Width="145" Height="36"
                Click="SettingsButton_Click">
            <Image Source="avares://Launcher/Resources/button_settings.png"
                   Stretch="None" />
        </Button>
        <!-- Mods Button -->
        <Button Canvas.Left="323" Canvas.Top="710" Width="88" Height="35"
                Click="ModsButton_Click">
            <Image Source="avares://Launcher/Resources/button_mods.png"
                   Stretch="None" />
        </Button>
        <!-- Exit Button -->
        <Button Canvas.Left="445" Canvas.Top="710" Width="75" Height="34"
                Click="ExitButton_Click">
            <Image Source="avares://Launcher/Resources/button_exit.png"
                   Stretch="None" />
        </Button>
    </Canvas>

</UserControl>